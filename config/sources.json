{
  "sources": [
    {
      "id": 1,
      "key": "jadedldn.com",
      "url": "https://jadedldn.com/",
      "adapter_key": "jadedldn__v1",
      "enabled": true,
      "sync_enabled": true,
      "config": {
        "adapter_ready": true,
        "adapter_revision": "jadedldn__v1-r2",
        "strategy_sequence": [
          "shopify_json",
          "shopify_js"
        ],
        "shopify_sitemap": {
          "max_products": 50000,
          "include_locale_sitemaps": false,
          "request_retries": 1
        },
        "shopify_json_quality": {
          "antibot_pause_sec": 3,
          "retry_backoff_sec": [
            1,
            3
          ],
          "enrich_from_js_fields": [
            "price",
            "images"
          ]
        },
        "shopify_js_workers": 7,
        "shopify_js_quality": {
          "progress_every": 100,
          "wait_log_sec": 15,
          "pause_poll_sec": 0.2,
          "antibot_pause_sec": 3,
          "retry_backoff_sec": [
            1,
            3
          ]
        },
        "retry_limits": {
          "shopify_json": 1,
          "shopify_js": 1
        },
        "timeouts": {
          "product_sec": 10,
          "source_run_sec": 300
        },
        "shopify_currency": {
          "allowed_currencies": [
            "EUR",
            "USD",
            "GBP"
          ],
          "use_storefront_currency_fallback": false,
          "requested_currency": "USD"
        }
      }
    },
